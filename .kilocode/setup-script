#!/usr/bin/env bash
# Kilo Cloud Agent setup for nitrocop cop-fix tasks.
# Called from Kilo startup commands: bash .kilocode/setup-script

exec > >(tee -a /tmp/setup.log) 2>&1
echo "=== Setup started at $(date) ==="

# Install C compiler only if missing (ruby-prism crate needs it for rebuilds)
if ! command -v cc &>/dev/null; then
  echo "--- Installing build tools ---"
  if command -v sudo &>/dev/null; then
    sudo apt-get update -qq && sudo apt-get install -y -qq build-essential
  else
    apt-get update -qq && apt-get install -y -qq build-essential
  fi
fi

# Install Rust only if missing
if ! command -v cargo &>/dev/null; then
  echo "--- Installing Rust ---"
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
  echo 'source "$HOME/.cargo/env"' >> "$HOME/.bashrc"
  echo 'source "$HOME/.cargo/env"' >> "$HOME/.profile"
fi
export PATH="$HOME/.cargo/bin:$PATH"

# Ensure submodules are checked out
if [ ! -d "vendor/rubocop/.git" ] && [ -f ".gitmodules" ]; then
  echo "--- Checking out submodules ---"
  git submodule update --init --recursive
fi

# Download pre-built build cache from GitHub Releases.
# The cache is SHA-stamped so we skip download if already current.
RELEASE_BASE="https://github.com/6/nitrocop/releases/download/agent-build-cache"
if [ ! -d "target/debug/deps" ]; then
  echo "--- Downloading pre-built cache ---"
  # Get the latest SHA
  LATEST_SHA=$(curl -sL --fail "${RELEASE_BASE}/latest-sha.txt" 2>/dev/null || echo "")
  if [ -n "$LATEST_SHA" ]; then
    CACHE_FILE="agent-build-cache-${LATEST_SHA}.tar.gz"
    mkdir -p target/debug
    if curl -sL --fail "${RELEASE_BASE}/${CACHE_FILE}" -o /tmp/cache.tar.gz; then
      tar xzf /tmp/cache.tar.gz -C target/debug/
      rm -f /tmp/cache.tar.gz
      echo "Build cache restored (${LATEST_SHA})"
    else
      echo "WARNING: could not download cache, will compile from scratch"
    fi
  else
    echo "WARNING: no cache available, will compile from scratch"
  fi
fi

# Quick incremental build (near-instant if cache matches, ~5min if cold)
echo "--- Incremental build ($(date)) ---"
cargo test --lib --no-run 2>&1 || echo "WARNING: build failed"
echo "--- Build done ($(date)) ---"

# Remove files that would confuse the agent
rm -f CLAUDE.md AGENTS.md
rm -rf .agents/ .claude/ .devcontainer/ .github/ bench/ docs/ gem/ scripts/

echo "=== Setup complete at $(date) ==="
